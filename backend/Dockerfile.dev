# ── Go Dev with Air hot-reload ─────────────────────────
FROM golang:1.22-alpine

RUN apk add --no-cache git ca-certificates

# Install Air for hot-reload (pin to v1.52.3 which supports Go 1.22)
RUN go install github.com/cosmtrek/air@v1.52.3

WORKDIR /app

# Copy dependency files first for caching
COPY go.mod go.sum ./
RUN go mod download

# Source code will be mounted via volume
EXPOSE 8080

CMD ["air", "-c", ".air.toml"]

