# ── Go Dev ─────────────────────────────────────────────
FROM golang:1.23-alpine

RUN apk add --no-cache git ca-certificates

WORKDIR /app

# Copy dependency files first for caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

EXPOSE 8080

CMD ["go", "run", "./cmd/server"]
