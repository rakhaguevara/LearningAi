# ===========================================
# Adaptive AI Learning Platform - Environment
# ===========================================
# Copy this file to .env:
#   cp .env.example .env       (Mac/Linux)
#   copy .env.example .env     (Windows CMD)
#
# For Docker mode (make dev / scripts/dev.bat):
#   DB_HOST dan REDIS_HOST harus tetap "postgres" dan "redis"
#   (ini adalah nama service Docker, JANGAN diganti ke localhost)
#
# For Local mode (tanpa Docker untuk backend/frontend):
#   Ganti DB_HOST=localhost dan REDIS_HOST=localhost
# ===========================================

# App
APP_ENV=development
APP_PORT=8080
APP_SECRET=your-app-secret-change-in-production
FRONTEND_URL=http://localhost:3000

# Frontend (diakses lewat browser, jadi selalu localhost)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Database (gunakan "postgres" untuk Docker, "localhost" untuk lokal)
DB_HOST=localhost
DB_PORT=5432
DB_USER=ailearndb
DB_PASSWORD=ailearndb_secret
DB_NAME=ailearn
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis (gunakan "redis" untuk Docker, "localhost" untuk lokal)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# Alibaba Cloud
ALIBABA_ACCESS_KEY_ID=your-alibaba-access-key-id
ALIBABA_ACCESS_KEY_SECRET=your-alibaba-access-key-secret
ALIBABA_REGION=cn-hangzhou

# Qwen LLM API
QWEN_API_KEY=sk-e8c85e9552094e49a91dd4258b50cc37
QWEN_API_ENDPOINT=https://dashscope.aliyuncs.com/api/v1
QWEN_MODEL=qwen-max

# Alibaba OSS
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=ailearn-assets
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret

# Rate Limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20