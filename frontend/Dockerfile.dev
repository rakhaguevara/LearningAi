# ── Node Dev with Next.js hot-reload ──────────────────
FROM node:20-alpine

WORKDIR /app

# Copy dependency files first for caching
COPY package.json package-lock.json* ./
RUN npm ci

# Source code will be mounted via volume
EXPOSE 3000

ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true

CMD ["npm", "run", "dev"]
